# PostgreSQL connection used by the app, drizzle-kit, and the migrate script.
# Matches the docker-compose service (`pnpm db:up`). Host port 5433 avoids
# colliding with a local Postgres that may already own 5432.
DATABASE_URL=postgresql://mhventanas:mhventanas@localhost:5433/mhventanas

# Connection used by the Vitest suite. Points at a separate database created by
# db/initdb.d/01-create-test-db.sql so tests never touch dev data.
TEST_DATABASE_URL=postgresql://mhventanas:mhventanas@localhost:5433/mhventanas_test

# Cloudflare R2 (S3-compatible API) for uploading WebM clips via `pnpm clips:upload`.
# R2_ENDPOINT is the S3 API endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mhventanas-clips

# Public base URL clips are served from (R2 public bucket or custom CDN domain).
# Distinct from R2_ENDPOINT. Ingest derives clip URLs as
# {CDN_BASE_URL}/{game}/{monster}/{slug}.webm
CDN_BASE_URL=https://pub-example.r2.dev
